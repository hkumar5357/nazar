# NAZAR environment variables — copy to .env and fill in. Never commit .env.
# Google Trends (pytrends) needs no key; everything below arrives later and
# the pipeline falls back to MOCK_* fixtures (clearly marked) until it does.

# YouTube Data API v3
YOUTUBE_API_KEY=

# Reddit API (script app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=nazar-radar/0.1 by <your-reddit-username>

# LLM labeling provider: gemini | openai | anthropic (default: gemini)
# Used ONLY for text labeling (cafe vs home/CPG intent) — never for
# lifecycle judgments. See PROTOCOL.md R5.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Google Trends backend: pytrends (default) | trendspy (fallback)
TRENDS_BACKEND=pytrends
